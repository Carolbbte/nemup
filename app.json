{
  "expo": {
    "name": "NemUp",
    "slug": "NemUp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nemup",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.NemUp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Nunito",
                "fontDefinitions": [
                  { "path": "./assets/fonts/Nunito-Regular.ttf", "weight": 400 },
                  { "path": "./assets/fonts/Nunito-Medium.ttf", "weight": 500 },
                  { "path": "./assets/fonts/Nunito-SemiBold.ttf", "weight": 600 },
                  { "path": "./assets/fonts/Nunito-Bold.ttf", "weight": 700 },
                  { "path": "./assets/fonts/Nunito-ExtraBold.ttf", "weight": 800 },
                  { "path": "./assets/fonts/Nunito-Black.ttf", "weight": 900 }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/Nunito-Regular.ttf",
              "./assets/fonts/Nunito-Medium.ttf",
              "./assets/fonts/Nunito-SemiBold.ttf",
              "./assets/fonts/Nunito-Bold.ttf",
              "./assets/fonts/Nunito-ExtraBold.ttf",
              "./assets/fonts/Nunito-Black.ttf"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
