{
  "name": "nemup-backend",
  "version": "1.0.0",
  "description": "Backend for NemUp - session generation pipeline with OpenAI",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker:dev": "tsx watch src/workers/generationWorker.ts",
    "worker": "node dist/workers/generationWorker.js",
    "estimate-cost": "tsx scripts/estimateCost.ts",
    "generate": "npm run build && npm start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bullmq": "^5.79.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.2.0",
    "ioredis": "^5.10.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.9.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.10.6",
    "@types/pdf-parse": "^1.1.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  }
}
